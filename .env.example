# ============================================================
# weather-pipeline — environment variables
# Salin file ini menjadi .env lalu isi nilainya
# JANGAN commit file .env ke Git
# ============================================================

# ── RustFS ──────────────────────────────────────────────────
RUSTFS_ACCESS_KEY=weatheradmin
RUSTFS_SECRET_KEY=            # min 8 karakter, contoh: generate dengan openssl rand -base64 16

# ── PostgreSQL (metadata Airflow) ───────────────────────────
POSTGRES_PASSWORD=            # contoh: airflow_secret_123

# ── Airflow ─────────────────────────────────────────────────
# Generate Fernet key dengan perintah:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=

# Password untuk login ke Airflow UI (user: admin)
AIRFLOW_ADMIN_PASSWORD=       # contoh: admin123
